# Copy to .env and fill in as needed. The pipeline runs fully offline/local
# by default and does not require any of these for the sample data to work.

# Default country code used by the phone normalizer when a number has no
# explicit country code (e.g. "415-555-0182" -> assumed US).
DEFAULT_PHONE_COUNTRY=US

# Override default config file location used by `python main.py run --config ...`
PIPELINE_CONFIG_PATH=config/default.yaml

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# Optional resume NER enhancement. Regex parsing remains the default.
RESUME_USE_NER=false
RESUME_NER_MODEL=en_core_web_sm
