{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CanonicalCandidateProfile",
  "type": "object",
  "required": ["profile_id", "name", "email", "processing_timestamp"],
  "properties": {
    "profile_id": {"type": "string"},
    "name": {"type": "object"},
    "email": {"type": "object"},
    "contact": {"type": ["object", "null"]},
    "skills": {"type": "array"},
    "experience": {"type": "array"},
    "education": {"type": "array"},
    "source_files": {"type": "array", "items": {"type": "string"}},
    "processing_timestamp": {"type": "string"},
    "total_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "merge_notes": {"type": "array"},
    "current_company": {"type": ["object", "null"]},
    "years_of_experience": {"type": ["object", "null"]},
    "job_titles": {"type": "array"},
    "certifications": {"type": "array"},
    "origin": {"type": "string", "enum": ["CSV", "RESUME_PDF", "MERGED", "UNKNOWN"]}
  }
}
